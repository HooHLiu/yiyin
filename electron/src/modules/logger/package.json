    "lint": "eslint . --ignore-path ./.eslintignore",
    "clean": "rimraf cjs esm",
    "test": "jest",
    "push": "yarn build && yarn publish"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.0",
